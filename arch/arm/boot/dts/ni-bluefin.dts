/dts-v1/;
/include/ "ni-zynq.dtsi"

/* NIDEVCODE 78C7 */
/* NIDEVCODE 78B9 */

/ {
	model = "NI Bluefin";
	compatible = "ni,zynq", "xlnx,zynq-7000";

	leds {
		compatible = "gpio-leds";

		/* LED_STATUSy on GPIO46 */
		status {
			label = "nilrt:status:yellow";
			gpios = <&gpio0 46 0>;
			default-state = "on";
		};

		/* LED_ACTIVEg on GPIO47 */
		active {
			label = "nilrt:active:green";
			gpios = <&gpio0 47 0>;
			default-state = "off";
		};
	};

	gpio_keys {
		compatible = "gpio-keys";
		#address-cells = <1>;
		#size-cells = <0>;

		/* Reset switch is on GPIO48 */
		reset_sw@0 {
			label = "reset_sw";
			gpios = <&gpio0 48 1 /* GPIO_ACTIVE_LOW */>;
			linux,code = <408>; /* KEY_RESTART */
			gpio-key,wakeup;
		};
	};

	gpio_restart {
		compatible = "gpio-restart";

		/* ~PS_FORCE_RESET is on GPIO44 */
		gpios = <&gpio0 44 1 /* GPIO_ACTIVE_LOW */>;
		priority = <200>;
	};
};

&i2c0 {
	status = "okay";
	clock-frequency = <400000>;

	eeprom: eeprom@52 {
		compatible = "atmel,24c02";
		status = "okay";
		reg = <0x52>;
	};

	ds3231_rtc@68 {
		compatible = "ds3232";
		status = "okay";
		reg = <0x68>;
	};

	tmp451@4c {
		compatible = "ti,tmp451";
		status = "okay";
		reg = <0x4c>;
		vcc-supply = <&regulator_vccpint>;
	};
};

&gem0 {
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;
	phy-mode = "rgmii-id";
	phy-handle = <&ethernet_phy>;

	ethernet_phy: ethernet-phy@1 {
		reg = <1>;
		device_type = "ethernet-phy";
	};

	mdio0: mdio {
		status = "okay";
		#address-cells = <1>;
		#size-cells = <0>;

		switch0: switch@0 {
			compatible = "marvell,mv88e6085";
			reg = <0>;

			ports {
				#address-cells = <1>;
				#size-cells = <0>;
	
				port@0 {
					reg = <0>;
					label = "cpu";
				};
	
				port@1 {
					reg = <1>;
					label = "sw0";
				};
	
				port@2 {
					reg = <2>;
					label = "sw1";
				};
			};
		};
	};

	fixed-link {
		speed = <1000>;
		full-duplex;
	};
};

&uart1 {
	status = "okay";
};

&usb0 {
	status = "okay";
	dr_mode = "host";
};

&watchdog0 {
	status = "okay";
	reset-on-timeout;
};

&nfc0 {
	status = "okay";

	nand@0 {
		reg = <0>;
	};
};

&smcc {
	status = "okay";
};
